# Puerto interno donde escucha Express (loopback)
PORT=

# Entorno: development | production
NODE_ENV=

# Nivel de logs: trace | debug | info | warn | error
LOG_LEVEL=

# Origen(es) permitidos por CORS. Acepta una URL o varias separadas por coma.
# Para desarrollo local con Vite añade http://localhost:5173.
LANDING_ORIGIN=

# URL del microservicio kd-service (FastAPI/Python en loopback).
# Tiene que coincidir con kd-service/.env -> PORT.
# Por defecto en producción: http://127.0.0.1:8001
KD_BASE_URL=

# API key compartida con kd-service. EL MISMO valor en ambos .env.
# Generar con:  openssl rand -hex 32
# (NUNCA commitear; sacar de 1Password / Bitwarden compartido).
KD_API_KEY= 

# Timeout (ms) para la llamada upstream a kd-service
KD_TIMEOUT_MS=
DEFAULT_KD_CATEGORIA=

# --- VoIPstudio (click-to-call) ---
# API key del panel de VoIPstudio (sección "API Keys"). Obligatoria.
VOIP_STUDIO_API_KEY=

# URL base de la API. Si está vacía se usa https://l7api.com/v1.2/voipstudio
VOIPSTUDIO_API_URL=

# Modo cola: id de la cola en VoIPstudio. Si está definido, el backend lee
# sus miembros y los intenta secuencialmente hasta que uno acepte (201).
# Si está vacío, se usa VOIP_DEFAULT_AGENT_ID (modo single-agent).
# Obtenerlo con:
#   curl https://l7api.com/v1.2/voipstudio/queues -H "X-Auth-Token: $VOIP_STUDIO_API_KEY"
VOIP_QUEUE_ID=

# user_id del agente fijo que recibirá la llamada (no es la extensión).
# Solo se usa si VOIP_QUEUE_ID está vacío.
# Obtenerlo con:
#   curl https://l7api.com/v1.2/voipstudio/users -H "X-Auth-Token: $VOIP_STUDIO_API_KEY"
VOIP_DEFAULT_AGENT_ID=

# Máximo de miembros a intentar por petición en modo cola (default 3).
VOIP_QUEUE_MAX_ATTEMPTS=