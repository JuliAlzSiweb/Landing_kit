# Puerto interno donde escucha Express (loopback)
PORT=

# Entorno: development | production
NODE_ENV=

# Nivel de logs: trace | debug | info | warn | error
LOG_LEVEL=

# Origen permitido por CORS. Si nginx sirve front y back en el mismo dominio,
# esto solo aplica si en algún momento llamas desde otro origen.
LANDING_ORIGIN=

# Servicio kd_contract_parser (en este servidor escucha en localhost)
KD_BASE_URL=

# API key del servicio kd_contract_parser (NUNCA commitear).
# Sacar de 1Password / Bitwarden compartido.
KD_API_KEY= 

# Timeout (ms) para la llamada upstream a kd_contract_parser
KD_TIMEOUT_MS=
DEFAULT_KD_CATEGORIA=