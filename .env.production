# URL base del backend en producción.
# El front usa esta variable para construir las llamadas al endpoint propio
# (kd_contract_parser proxy y click-to-call de VoIPstudio).
# nginx en siwebcanarias.es hace proxy de /api/ a 127.0.0.1:5001.
# Ver src/config/leadWebhook.js
VITE_API_BASE=https://siwebcanarias.es/api
