# Puerto interno donde escucha FastAPI (loopback). Debe coincidir con KD_BASE_URL del Node.
PORT=8001

# Entorno: development | production
ENV=production

# Nivel de logs: debug | info | warning | error
LOG_LEVEL=info

# API key compartida con el backend Node. Debe coincidir EXACTAMENTE con KD_API_KEY de server/.env.
# Genera una nueva con:  openssl rand -hex 32
API_KEY=

# Ruta absoluta o relativa al fichero cookies.json con la sesion DWR del portal.
# El fichero se carga al arrancar y al llamar a POST /admin/reload-session.
# Mientras esten validas las cookies, el servicio responde; cuando expiren hay que
# regenerar el fichero (ver README) y llamar al endpoint de reload.
COOKIES_PATH=./cookies.json

# Origen(es) permitidos por CORS. Por defecto NINGUNO porque solo deberia
# llamarte el Node por loopback. Solo descomentar si quieres pegarle directamente
# desde el navegador en debug.
# CORS_ORIGINS=http://localhost:5173
